# ============================================================
# RevendaHub - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SUA_SENHA_SEGURA_AQUI
POSTGRES_DB=revendahub

# JWT - OBRIGATÓRIO mudar em produção (mínimo 32 chars)
JWT_SECRET=MUDE_ESTA_CHAVE_JWT_PARA_ALGO_MUITO_SEGURO_EM_PRODUCAO

# Criptografia de dados sensíveis (exatamente 32 chars)
ENCRYPTION_KEY=MUDE_ESTA_CHAVE_32_CHARS_SEGURA_

# Origem permitida para CORS (URL do seu domínio em produção)
WEB_ORIGIN=https://seudominio.com.br

# Ambiente
NODE_ENV=production
